    if (patternAddress != 0) {
        std::cout << "Pattern found at address: " << std::hex << patternAddress << std::endl;
        PyRun_StringFlags = (PyRun_StringFlags_t)((uintptr_t)patternAddress);

        // Log the offset to a file
        std::ofstream logFile(logFilePath);
        if (logFile.is_open()) {
            logFile << "Base Address: " << std::hex << baseAddress << std::endl;
            logFile << "Pattern Address: " << std::hex << patternAddress << std::endl;
            logFile << "Offset: " << std::hex << (patternAddress - baseAddress) << std::endl;
            logFile.close();
            std::cout << "Offset logged to " << logFilePath << std::endl;
        } else {
            std::cout << "Failed to open log file." << std::endl;
        }
    } else {
        std::cout << "Pattern not found." << std::endl;
    }
} else {
    std::cout << "Failed to get base address." << std::endl;
}
    
    sleep(3); 
    hookFunctions();
    p_glGetIntegerv = (void (*)(unsigned int, int *))((const void*(*)(...))dlsym(dlopen(xorstr_("libGLESv3.so"), 4), xorstr_("glGetIntegerv")));
