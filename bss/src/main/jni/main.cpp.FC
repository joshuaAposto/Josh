// Function to log offset to file
void logOffset(uintptr_t offset, const std::string& patternName) {
    std::string logFilePath = "/sdcard/offset_log.txt";
    std::ofstream logFile(logFilePath, std::ios_base::app);
    if (logFile.is_open()) {
        logFile << patternName << " offset: " << std::hex << offset << std::endl;
        logFile.close();
    } else {
        printf("Unable to open log file\n");
    }
}
