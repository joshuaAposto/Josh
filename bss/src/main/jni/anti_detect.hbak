// ==================== MEMORY PROTECTION ====================

void ProtectMemoryRegion(uintptr_t address, size_t size) {
    long pageSize = sysconf(_SC_PAGESIZE);
    uintptr_t alignedAddr = (address & ~(pageSize - 1));
    
    // Set memory ke read-only setelah patch untuk hindari deteksi
    mprotect((void*)alignedAddr, pageSize, PROT_READ | PROT_EXEC);
}

// ==================== STRING OBFUSCATION ====================

// Sudah ada xorstr.hpp, tapi tambahkan runtime encryption
std::string DecryptString(const char* encrypted, size_t len, uint8_t key) {
    std::string result;
    for (size_t i = 0; i < len; i++) {
        result += encrypted[i] ^ key ^ (i & 0xFF);
    }
    return result;
}

// ==================== ANTI DEBUGGING ====================

bool IsDebuggerAttached() {
    // Check TracerPid in /proc/self/status
    FILE* fp = fopen("/proc/self/status", "r");
    if (!fp) return false;
    
    char line[256];
    bool debugged = false;
    
    while (fgets(line, sizeof(line), fp)) {
        if (strncmp(line, "TracerPid:", 10) == 0) {
            int pid = atoi(line + 10);
            debugged = (pid != 0);
            break;
        }
    }
    fclose(fp);
    
    // Return false untuk bypass
    return false;
}

