{
  "version": 2,
  "builds": [
    { "src": "server.js", "use": "@vercel/node" },
    { "src": "public/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/logo/(.*)", "dest": "/public/logo/$1" },
    { "src": "/admin.html", "dest": "/public/admin.html" },
    { "src": "/(.*)", "dest": "server.js" }
  ]
}
